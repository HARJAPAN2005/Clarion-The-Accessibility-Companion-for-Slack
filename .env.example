# ==============================================================================
# Clarion — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values.
#
#   cp .env.example .env
#
# NEVER commit your .env file. It is listed in .gitignore.
# ==============================================================================


# ------------------------------------------------------------------------------
# Slack — Required for all modes
# ------------------------------------------------------------------------------

# Bot User OAuth Token — from https://api.slack.com/apps → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App-Level Token — needed for Socket Mode. Requires the `connections:write` scope.
# Create one at https://api.slack.com/apps → App-Level Tokens
SLACK_APP_TOKEN=xapp-your-app-level-token-here


# ------------------------------------------------------------------------------
# AI Provider — OpenRouter (primary text model)
# ------------------------------------------------------------------------------

# Your OpenRouter API key from https://openrouter.ai/keys
# Clarion works without this key using a deterministic offline fallback,
# but you will need it for real AI-powered responses.
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Text model to use for message simplification, thread digests, and inclusive checks.
# Any model available on OpenRouter works. Free models are fine for evaluation.
# Default: poolside/laguna-xs-2.1:free
OPENROUTER_MODEL=poolside/laguna-xs-2.1:free

# Vision model to use for image descriptions (via OpenRouter).
# Only needed if you don't have a GEMINI_API_KEY.
# Example: google/gemini-pro-vision, openai/gpt-4o
OPENROUTER_VISION_MODEL=


# ------------------------------------------------------------------------------
# AI Provider — Google Gemini (preferred for image descriptions)
# ------------------------------------------------------------------------------

# Google Gemini API key from https://aistudio.google.com/app/apikey
# When set, Clarion uses Gemini for image descriptions (better accuracy).
# The Gemini 2.0 Flash model is used by default.
GEMINI_API_KEY=


# ------------------------------------------------------------------------------
# Slack Real-Time Search API (optional — for live jargon definitions)
# ------------------------------------------------------------------------------

# When set, the "define_term" feature searches your live Slack workspace
# to ground definitions in how your team actually uses the term.
# Falls back to a built-in demo glossary when not configured.
SLACK_RTS_TOKEN=

# Override the RTS endpoint if your workspace uses a custom or regional URL.
# Default: https://slack.com/api/search.realtime
SLACK_RTS_ENDPOINT=https://slack.com/api/search.realtime


# ------------------------------------------------------------------------------
# HTTP + OAuth mode (only needed when running app_oauth.py)
# ------------------------------------------------------------------------------

# Enable the Slack MCP Server for governed thread history access.
# Set to "true" only when running app_oauth.py.
SLACK_MCP_ENABLED=false

# From https://api.slack.com/apps → App Credentials
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Your public-facing redirect URL for OAuth. In development, use ngrok.
# Example: https://your-subdomain.ngrok-free.app/slack/oauth_redirect
SLACK_REDIRECT_URI=

# HTTP server port (default: 3000)
PORT=3000
